#
# pca gfloor_g* kitchen_g* toilet_g* sselectric rmfsize_g* ///
#     ssirrpump_g ssradios_g sscycle_g ssrickshaw_g almira_g* ssdtable_g clock_g* sssewmach_g sstv_g ssmotorc_g mobile_g* woodbedHhs_g* ///
